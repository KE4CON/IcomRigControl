<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:IcomRigControl.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="IcomRigControl.UI.Views.MemoryEditorWindow"
        x:DataType="vm:MemoryEditorViewModel"
        Title="Memory Channel Editor"
        Width="700" Height="600"
        Background="#1a1a1a">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <Button Content="Read All Channels" Command="{Binding ReadAllChannelsCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Background="#2a2a2a" Foreground="White" Padding="10,6">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#00ff88"/>
                        <Setter Property="TextBlock.Foreground" Value="Black"/>
                    </Style>
                </Button.Styles>
            </Button>
            <Button Content="Write All Channels" Command="{Binding WriteAllChannelsCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Background="#2a2a2a" Foreground="White" Padding="10,6">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#00ff88"/>
                        <Setter Property="TextBlock.Foreground" Value="Black"/>
                    </Style>
                </Button.Styles>
            </Button>
            <Button Content="Add Channel" Command="{Binding AddEmptyChannelCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Background="#2a2a2a" Foreground="White" Padding="10,6">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#00ff88"/>
                        <Setter Property="TextBlock.Foreground" Value="Black"/>
                    </Style>
                </Button.Styles>
            </Button>
            <Button Content="Cancel" Command="{Binding CancelReadCommand}"
                    IsEnabled="{Binding IsBusy}"
                    Background="#5a2a2a" Foreground="White" Padding="10,6">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Red"/>
                        <Setter Property="TextBlock.Foreground" Value="White"/>
                    </Style>
                </Button.Styles>
            </Button>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,10">
            <TextBlock Text="{Binding ProgressText}" Foreground="#88ccff" FontSize="12"/>
            <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100" Height="6"/>
        </StackPanel>

        <!-- Channel list -->
        <ScrollViewer Grid.Row="2">
            <StackPanel>
                <!-- Header row -->
                <Grid ColumnDefinitions="60,160,90,*" Background="#2a2a2a" Margin="0,0,0,2">
                    <TextBlock Grid.Column="0" Text="Ch" Foreground="White" FontWeight="Bold" Padding="8,6"/>
                    <TextBlock Grid.Column="1" Text="Frequency (Hz)" Foreground="White" FontWeight="Bold" Padding="8,6"/>
                    <TextBlock Grid.Column="2" Text="Mode" Foreground="White" FontWeight="Bold" Padding="8,6"/>
                    <TextBlock Grid.Column="3" Text="Name" Foreground="White" FontWeight="Bold" Padding="8,6"/>
                </Grid>

                <!-- Data rows -->
                <ItemsControl ItemsSource="{Binding Channels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="60,160,90,*" Background="#0d0d0d" Margin="0,0,0,1">
                                <TextBlock Grid.Column="0" Text="{Binding ChannelNumber}" Foreground="#00ff88" Padding="8,6"/>
                                <TextBlock Grid.Column="1" Text="{Binding FrequencyHz}" Foreground="#00ff88" Padding="8,6"/>
                                <TextBlock Grid.Column="2" Text="{Binding Mode}" Foreground="#88ccff" Padding="8,6"/>
                                <TextBlock Grid.Column="3" Text="{Binding Name}" Foreground="White" Padding="8,6"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Text="{Binding Channels.Count, StringFormat='{}{0} channels loaded'}"
                   Foreground="Gray" FontSize="11" Margin="0,8,0,0"/>
    </Grid>
</Window>