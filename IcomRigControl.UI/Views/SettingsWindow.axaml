<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:IcomRigControl.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="1150"
        x:Class="IcomRigControl.UI.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="500" Height="1150"
        Background="#1a1a1a">

    <ScrollViewer>
    <StackPanel Margin="20" Spacing="16">

        <TextBlock Text="Radio Connection (Phase 9)" Foreground="#88ccff" FontSize="14" FontWeight="Bold"/>
        <Border Background="#0d0d0d" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Connection Mode" Foreground="Gray" FontSize="11"/>
                <ComboBox ItemsSource="{Binding AvailableConnectionModes}"
                          SelectedItem="{Binding ConnectionMode}"
                          HorizontalAlignment="Stretch"/>
                <TextBlock Text="Demo: no hardware needed. Serial: local USB radio. Remote: connect to a CivTcpServer over TCP (e.g. a Pi running --headless-server, possibly over 44Net/AMPRNet)."
                           Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>

                <TextBlock Text="Serial Port (Serial mode)" Foreground="Gray" FontSize="11" Margin="0,8,0,0"/>
                <TextBox Text="{Binding SerialPortName}" PlaceholderText="COM3 or /dev/tty.usbserial-XXXX"/>

                <TextBlock Text="Remote Host (Remote mode)" Foreground="Gray" FontSize="11" Margin="0,8,0,0"/>
                <TextBox Text="{Binding RemoteHost}" PlaceholderText="44.xx.xx.xx or hostname"/>
                <TextBlock Text="Remote Port" Foreground="Gray" FontSize="11"/>
                <NumericUpDown Value="{Binding RemotePort}" Minimum="1" Maximum="65535"/>
                <TextBlock Text="Remote Auth Token" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding RemoteAuthToken}" PasswordChar="*"/>
            </StackPanel>
        </Border>

        <TextBlock Text="APRS Beacon (Phase 10)" Foreground="#88ccff" FontSize="14" FontWeight="Bold"/>
        <Border Background="#0d0d0d" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Callsign" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding AprsCallsign}" PlaceholderText="KE4CON"/>
                <TextBlock Text="SSID (9 is conventional for mobile/HF APRS)" Foreground="Gray" FontSize="11"/>
                <NumericUpDown Value="{Binding AprsSsid}" Minimum="0" Maximum="15"/>
                <TextBlock Text="Symbol Table (usually /)" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding AprsSymbolTable}" MaxLength="1"/>
                <TextBlock Text="Symbol Code (&gt; for car/mobile)" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding AprsSymbolCode}" MaxLength="1"/>
                <TextBlock Text="Comment" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding AprsComment}" PlaceholderText="Optional comment text"/>
                <TextBlock Text="Latitude (decimal degrees, negative for South)" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding AprsLatitude}"/>
                <TextBlock Text="Longitude (decimal degrees, negative for West)" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding AprsLongitude}"/>
                <TextBlock Text="Audio Output Device" Foreground="Gray" FontSize="11" Margin="0,8,0,0"/>
                <ComboBox ItemsSource="{Binding AvailableAudioDevices}"
                          SelectedItem="{Binding AudioOutputDeviceName}"
                          HorizontalAlignment="Stretch"/>
                <TextBlock Text="Select the audio interface connected to the radio (e.g. its USB audio device, or an external soundcard wired to the mic/data port)."
                           Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Text="Callsign Lookup (Phase 8c)" Foreground="#88ccff" FontSize="14" FontWeight="Bold"/>
        <Border Background="#0d0d0d" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Lookup Source" Foreground="Gray" FontSize="11"/>
                <ComboBox ItemsSource="{Binding AvailableLookupSources}"
                          SelectedItem="{Binding CallsignLookupSource}"
                          HorizontalAlignment="Stretch"/>
                <TextBlock Text="QRZ.com Username (requires paid subscription)" Foreground="Gray" FontSize="11" Margin="0,8,0,0"/>
                <TextBox Text="{Binding QrzUsername}"/>
                <TextBlock Text="QRZ.com Password" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding QrzPassword}" PasswordChar="*"/>
                <TextBlock Text="HamQTH.com Username (free, requires registration)" Foreground="Gray" FontSize="11" Margin="0,8,0,0"/>
                <TextBox Text="{Binding HamQthUsername}"/>
                <TextBlock Text="HamQTH.com Password" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding HamQthPassword}" PasswordChar="*"/>
            </StackPanel>
        </Border>

        <TextBlock Text="Logbook of the World (Phase 8d)" Foreground="#88ccff" FontSize="14" FontWeight="Bold"/>
        <Border Background="#0d0d0d" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="TQSL executable path (requires TQSL already installed via ARRL)" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding TqslExecutablePath}"
                         PlaceholderText="C:\Program Files (x86)\TrustedQSL\tqsl.exe"/>
            </StackPanel>
        </Border>

        <TextBlock Text="Ham Radio Deluxe (Phase 8e)" Foreground="#88ccff" FontSize="14" FontWeight="Bold"/>
        <Border Background="#0d0d0d" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <ToggleButton Content="{Binding HrdBridgeEnabled, Converter={x:Static vm:LoggingButtonTextConverter.Instance}}"
                              IsChecked="{Binding HrdBridgeEnabled}"
                              Width="200" HorizontalAlignment="Left"
                              Background="#2a2a2a" Foreground="White"/>
                <TextBlock Text="HRD Logbook database path" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding HrdDatabasePath}"
                         PlaceholderText="C:\Users\...\AppData\Roaming\Simon Brown, HB9DRV\HRD Logbook\..."/>
            </StackPanel>
        </Border>

        <TextBlock Text="N1MM / WSJT-X Integration (Phase 8f)" Foreground="#88ccff" FontSize="14" FontWeight="Bold"/>
        <Border Background="#0d0d0d" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <ToggleButton Content="{Binding N1mmSendEnabled, Converter={x:Static vm:LoggingButtonTextConverter.Instance}}"
                              IsChecked="{Binding N1mmSendEnabled}"
                              Width="200" HorizontalAlignment="Left"
                              Background="#2a2a2a" Foreground="White"/>
                <TextBlock Text="Destination (IP:Port)" Foreground="Gray" FontSize="11"/>
                <TextBox Text="{Binding N1mmDestinationInput}" PlaceholderText="127.0.0.1:12060"/>
                <ToggleButton Content="{Binding N1mmReceiveEnabled, Converter={x:Static vm:LoggingButtonTextConverter.Instance}}"
                              IsChecked="{Binding N1mmReceiveEnabled}"
                              Width="200" HorizontalAlignment="Left"
                              Background="#2a2a2a" Foreground="White" Margin="0,8,0,0"/>
                <TextBlock Text="Listen Port" Foreground="Gray" FontSize="11"/>
                <NumericUpDown Value="{Binding ContactListenPort}" Minimum="1" Maximum="65535"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,0">
            <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}"
                    Width="140" Background="#2a2a2a" Foreground="White" Padding="10,8">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#00ff88"/>
                        <Setter Property="TextBlock.Foreground" Value="Black"/>
                    </Style>
                </Button.Styles>
            </Button>
        </StackPanel>
        <TextBlock Text="{Binding StatusMessage}" Foreground="#00ff88" FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap"/>

    </StackPanel>
    </ScrollViewer>
</Window>